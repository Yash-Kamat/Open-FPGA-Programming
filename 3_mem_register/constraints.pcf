# ---------------------------
# I2C (unchanged)
# ---------------------------
set_io scl 47
set_io sda 44

# ---------------------------
# 3x3 LED Matrix Mapping
# (Row-wise mapping)
# ---------------------------

# Row 1
set_io led[0] 2
set_io led[1] 3
set_io led[2] 4

# Row 2
set_io led[3] 6
set_io led[4] 9
set_io led[5] 10

# Row 3
set_io led[6] 11
set_io led[7] 12
set_io led[8] 13